datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

//////////////////////////////////////////////////////
// PLAN
//////////////////////////////////////////////////////

model Plan {
  id                  String   @id
  name                String
  description         String?
  price               Int
  currency            String

  billing_interval    String?   // MONTH | YEAR

  isFree              Boolean   @default(true)

  paypal_plan_id      String?   @unique
  paypal_product_id   String?

  environment         String    // sandbox | live
  version             Int
  isActive            Boolean

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscriptions       Subscription[]
  limits              PlanLimit[]

  @@index([environment, isActive])
}

//////////////////////////////////////////////////////
// PLAN LIMITS
//////////////////////////////////////////////////////

model PlanLimit {
  id            String   @id @default(cuid())

  plan_id       String
  plan          Plan     @relation(fields: [plan_id], references: [id])

  text_limit    Int
  image_limit   Int

  interval      String   // WEEK | MONTH

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([plan_id, interval])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION
//////////////////////////////////////////////////////

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
  APPROVAL_PENDING
}

model Subscription {
  id                      String   @id @default(cuid())

  firebase_uid            String

  plan_id                 String
  plan                    Plan @relation(fields: [plan_id], references: [id])

  paypal_subscription_id  String? @unique

  status                  SubscriptionStatus

  start_date              DateTime?
  next_billing_date       DateTime?
  end_date                DateTime?

  cancel_at_period_end    Boolean @default(false)

  grace_period_end        DateTime?
  failed_payment_count    Int @default(0)

  last_payment_date       DateTime?
  last_payment_amount     Int?
  currency                String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
 
  @@index([firebase_uid, status])
  @@index([firebase_uid, end_date])
  @@index([status])
  @@index([next_billing_date])
}

//////////////////////////////////////////////////////
// USAGE
//////////////////////////////////////////////////////

model Usage {
  id              String   @id @default(cuid())

  firebase_uid    String
  plan_id         String

  text_count      Int      @default(0)
  image_count     Int      @default(0)

  period_start    DateTime
  period_end      DateTime

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([firebase_uid, plan_id, period_start])
  @@index([firebase_uid])
}